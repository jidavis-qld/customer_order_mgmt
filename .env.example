# ─── Gmail access via Service Account + Domain-Wide Delegation ───────────────
#
# Full service account key JSON, as a single string (same pattern as in_demandSOP).
# This service account must have Domain-Wide Delegation enabled in Google Workspace
# Admin (Security → API Controls → Domain-wide Delegation) with scope:
#   https://www.googleapis.com/auth/gmail.readonly
#
# In Cloud Run, set this as an environment variable in the console.
# For local development, either set this variable or point GOOGLE_APPLICATION_CREDENTIALS
# to the path of a service account key JSON file on disk.
#
GOOGLE_CREDENTIALS_JSON=

# ─── Anthropic API ────────────────────────────────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Server ───────────────────────────────────────────────────────────────────
# Cloud Run default port — do not change for production
PORT=8080

# URL path prefix — must match the load balancer path rule
APP_BASE_PATH=/orders
