# Google OAuth (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match the redirect URI configured in your Google OAuth app
GOOGLE_REDIRECT_URI=https://app.fablefood.co/orders/auth/callback

# Gmail refresh token — obtained by visiting /orders/auth/setup once.
# After completing OAuth, copy the token shown and paste it here.
GMAIL_REFRESH_TOKEN=

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Express session secret — generate with: openssl rand -hex 32
SESSION_SECRET=

# Cloud Run default port — do not change for production
PORT=8080

# URL path prefix for the app (must match load balancer routing)
APP_BASE_PATH=/orders
